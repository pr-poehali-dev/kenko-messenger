{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "List without token unauthorized",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Send without token unauthorized",
      "method": "POST",
      "path": "/?action=send",
      "body": {"chat_id": 1, "text": "hi"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}
